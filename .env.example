# ============================================================================
# AI Solution Architect Generator — LLM Provider Configuration
# ----------------------------------------------------------------------------
# This app talks to any OpenAI-compatible Chat Completions endpoint.
# To run in Demo Mode (no external calls, fully offline), leave LLM_API_KEY
# empty. A built-in mock provider will generate a complete sample solution.
# ============================================================================

# API key. Leave empty to enable Demo Mode.
LLM_API_KEY=

# OpenAI-compatible base URL.
#   OpenAI:        https://api.openai.com/v1
#   Azure OpenAI:  https://<resource>.openai.azure.com/openai/deployments/<dep>
#   Self-hosted:   http://localhost:11434/v1   (Ollama), http://localhost:8000/v1 (vLLM)
LLM_BASE_URL=https://api.openai.com/v1

# Chat model to use.
LLM_MODEL=gpt-4o

# Display name of the provider (shown in the UI status badge).
LLM_PROVIDER_NAME=OpenAI

# Sampling temperature (0 = deterministic, 1 = creative). Low values keep
# architecture proposals consistent and defensible.
LLM_TEMPERATURE=0.4

# Request JSON-object response format. Set to false if your provider does not
# support response_format: { type: "json_object" }.
LLM_JSON_MODE=true
